# =============================================================================
# LAOZI AI — ENVIRONMENT VARIABLE CONTRACT
# =============================================================================
# Copy this file to .env.local for local development.
# All variables marked REQUIRED must be set for the application to start.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
# REQUIRED. Full PostgreSQL connection string.
# For Vercel Postgres / Neon: include ?sslmode=require
# For pgBouncer (recommended for serverless): add ?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://user:password@localhost:5432/laozi?schema=public"

# REQUIRED for Prisma migrations (direct connection, bypasses pgBouncer).
# If not using pgBouncer, set this to the same value as DATABASE_URL.
DIRECT_URL="postgresql://user:password@localhost:5432/laozi?schema=public"

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
# REQUIRED. Public base URL of the application.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# REQUIRED. Secret key for signing session tokens (minimum 32 characters).
# Generate with: openssl rand -base64 32
SESSION_SECRET="replace-with-at-least-32-character-secret-key-here"

# -----------------------------------------------------------------------------
# AI PROVIDERS
# -----------------------------------------------------------------------------
# REQUIRED (at least one provider must be configured).
# Active provider: "anthropic" or "openai"
AI_PROVIDER="anthropic"

# Anthropic Claude API key (required if AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY="sk-ant-..."

# OpenAI API key (required if AI_PROVIDER=openai)
OPENAI_API_KEY="sk-..."

# Default Anthropic model to use
ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"

# Default OpenAI model to use
OPENAI_MODEL="gpt-4o"

# -----------------------------------------------------------------------------
# EMAIL (SMTP)
# -----------------------------------------------------------------------------
# REQUIRED for email verification and password reset.
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="noreply@example.com"
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM="Laozi AI <noreply@example.com>"

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
# Max chat requests per user per hour
RATE_LIMIT_CHAT_MAX="20"
RATE_LIMIT_CHAT_WINDOW_SECONDS="3600"

# Max auth requests per IP per 15 minutes
RATE_LIMIT_AUTH_MAX="10"
RATE_LIMIT_AUTH_WINDOW_SECONDS="900"

# Max feedback requests per user per hour
RATE_LIMIT_FEEDBACK_MAX="30"
RATE_LIMIT_FEEDBACK_WINDOW_SECONDS="3600"

# Max contact requests per IP per hour
RATE_LIMIT_CONTACT_MAX="5"
RATE_LIMIT_CONTACT_WINDOW_SECONDS="3600"

# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
# REQUIRED. Comma-separated list of allowed origins for CORS (if needed).
# In production, this should be your domain only.
ALLOWED_ORIGINS="http://localhost:3000"

# Session cookie max age in seconds (default: 30 days)
SESSION_MAX_AGE="2592000"

# -----------------------------------------------------------------------------
# ADMIN
# -----------------------------------------------------------------------------
# Initial admin email (used by seed script only, not runtime)
ADMIN_EMAIL="admin@laozi.ai"
ADMIN_PASSWORD="Admin123!ChangeThis"

# -----------------------------------------------------------------------------
# OBSERVABILITY (optional)
# -----------------------------------------------------------------------------
# Log level: "error" | "warn" | "info" | "debug"
LOG_LEVEL="info"

# Enable structured JSON logging in production
LOG_JSON="true"

# =============================================================================
# VERCEL DEPLOYMENT NOTES
# =============================================================================
# 1. Set all REQUIRED variables in Vercel project settings > Environment Variables
# 2. DATABASE_URL should point to your production PostgreSQL (Neon, Railway, etc.)
# 3. DIRECT_URL is needed for prisma migrate deploy during build
# 4. SESSION_SECRET must be the same across all instances/deployments
# 5. SMTP credentials should be from a transactional email provider (Postmark, SES, etc.)
# 6. AI_PROVIDER and corresponding API key must be set
# =============================================================================
